generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String                @id @default(cuid())
  name          String
  email         String                @unique
  passwordHash  String
  role          UserRole              @default(USER)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  companies     Company[]
  invoices      Invoice[]             @relation("UserInvoices")
  itemTemplates InvoiceItemTemplate[]
  mailTemplates MailTemplate[]
  systemSetting SystemSetting?
}

model Company {
  id             String                  @id @default(cuid())
  name           String
  invoiceCode    String
  userId         String
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  billingCcEmail String?
  billingEmail   String?
  commonSubject  String?
  defaultDueDays Int                     @default(30)
  paymentTerms   String?
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  sequences      InvoiceNumberSequence[]

  @@unique([userId, invoiceCode])
  @@index([userId])
}

model Invoice {
  id                 String        @id @default(cuid())
  invoiceNumber      String        @unique
  companyId          String
  subject            String
  issueDate          DateTime
  dueDate            DateTime
  subtotal           Int
  taxRate            Int
  taxAmount          Int
  totalWithTax       Int
  withholdingEnabled Boolean       @default(false)
  withholdingTax     Int
  grandTotal         Int
  status             InvoiceStatus @default(DRAFT)
  createdById        String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  autosaveUpdatedAt  DateTime?
  /// * ログイン不要の帳票共有用トークン
  shareToken         String?       @unique
  company            Company       @relation(fields: [companyId], references: [id])
  createdBy          User          @relation("UserInvoices", fields: [createdById], references: [id])
  items              InvoiceItem[]

  @@index([createdById])
  @@index([companyId])
  @@index([issueDate])
  @@index([status])
  @@index([withholdingEnabled])
}

model InvoiceItem {
  id                   String   @id @default(cuid())
  invoiceId            String
  sortOrder            Int
  productName          String
  unit                 String?
  quantity             Decimal  @db.Decimal(12, 2)
  unitPrice            Int
  amount               Int
  amountManuallyEdited Boolean  @default(false)
  note                 String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  invoice              Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, sortOrder])
  @@index([invoiceId])
}

/// ユーザーごとの明細テンプレート（よく使う行をワンクリック追加）
model InvoiceItemTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  productName String
  unit        String?
  quantity    Decimal  @db.Decimal(12, 2)
  unitPrice   Int
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// ユーザーごとのメールテンプレート（変数差し込みは {{key}} 形式）
model MailTemplate {
  id              String   @id @default(cuid())
  userId          String
  name            String
  subjectTemplate String
  bodyTemplate    String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SystemSetting {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  companyName               String
  invoiceRegistrationNumber String?
  postalCode                String?
  address                   String?
  phone                     String?
  email                     String?
  contactPerson             String?
  stampImageUrl             String?
  bankName                  String?
  branchName                String?
  accountType               String?
  accountNumber             String?
  accountHolder             String?
  accountHolderKana         String?
  transferNote              String?
  taxRate                   Int      @default(1000)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InvoiceNumberSequence {
  id        String   @id @default(cuid())
  companyId String
  yearMonth String
  lastSeq   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, yearMonth])
  @@index([companyId])
}

enum UserRole {
  USER
  ADMIN
}

enum InvoiceStatus {
  DRAFT
  CONFIRMED
  ISSUED
}
