generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum InvoiceStatus {
  DRAFT
  CONFIRMED
  ISSUED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(USER)

  companies         Company[]
  invoices          Invoice[]             @relation("UserInvoices")
  itemTemplates     InvoiceItemTemplate[]
  mailTemplates     MailTemplate[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Company {
  id          String   @id @default(cuid())
  name        String
  invoiceCode String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 請求書作成時の自動入力用（顧客マスタ強化）
  defaultDueDays  Int     @default(30) // 請求日から何日後を支払期限の初期値にするか
  paymentTerms    String? // 振込条件・備考（帳票・メールで利用）
  commonSubject   String? // よく使う件名（初期値候補）
  billingEmail    String? // 請求書送付先 To
  billingCcEmail  String? // CC（任意）

  invoices    Invoice[]
  sequences   InvoiceNumberSequence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, invoiceCode])
  @@index([userId])
}

model Invoice {
  id                String        @id @default(cuid())
  invoiceNumber     String        @unique

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  subject    String
  issueDate  DateTime
  dueDate    DateTime

  subtotal     Int
  taxRate      Int
  taxAmount    Int
  totalWithTax Int

  withholdingEnabled Boolean @default(false)
  withholdingTax     Int
  grandTotal         Int

  status InvoiceStatus @default(DRAFT)

  /** ログイン不要の帳票共有用トークン */
  shareToken String? @unique

  createdById String
  createdBy   User   @relation("UserInvoices", fields: [createdById], references: [id], onDelete: Restrict)

  items InvoiceItem[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  autosaveUpdatedAt DateTime? // 自動保存時刻（DRAFT時のUX用）

  @@index([createdById])
  @@index([companyId])
  @@index([issueDate])
  @@index([status])
  @@index([withholdingEnabled])
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  sortOrder            Int
  productName          String
  unit                 String?
  quantity             Decimal  @db.Decimal(12, 2)
  unitPrice            Int
  amount               Int
  amountManuallyEdited Boolean  @default(false)
  note                 String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([invoiceId, sortOrder])
  @@index([invoiceId])
}

/// ユーザーごとの明細テンプレート（よく使う行をワンクリック追加）
model InvoiceItemTemplate {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String // 一覧表示用ラベル
  productName String
  unit        String?
  quantity    Decimal  @db.Decimal(12, 2)
  unitPrice   Int
  note        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// ユーザーごとのメールテンプレート（変数差し込みは {{key}} 形式）
model MailTemplate {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  subjectTemplate String
  bodyTemplate    String   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model SystemSetting {
  id                        String  @id @default("singleton")
  companyName               String
  invoiceRegistrationNumber String?
  postalCode                String?
  address                   String?
  phone                     String?
  email                     String?
  contactPerson             String?
  stampImageUrl             String?

  bankName          String?
  branchName        String?
  accountType       String?
  accountNumber     String?
  accountHolder     String?
  accountHolderKana String?
  transferNote      String?

  taxRate Int @default(1000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceNumberSequence {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  yearMonth String
  lastSeq   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, yearMonth])
  @@index([companyId])
}
